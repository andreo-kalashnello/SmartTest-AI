# Публічний URL (OpenRouter referer, production)
NEXT_PUBLIC_APP_URL="http://smarttestai.duckdns.org"

DATABASE_URL="postgresql://smarttest:smarttest@localhost:5433/smarttest?schema=public"
AUTH_SECRET="change-me-in-production-at-least-32-chars"
OPENROUTER_API_KEY=""
# Без reasoning — стабільніший JSON. Альтернатива: baidu/cobuddy:free (потрібно 4000+ токенів)
OPENROUTER_MODEL="google/gemma-2-9b-it:free"
OPENROUTER_MAX_TOKENS="4000"
OPENROUTER_TIMEOUT_MS="90000"
OPENROUTER_VISION_MODEL="google/gemini-2.0-flash-lite-001"
AI_UPLOAD_MAX_BYTES="5242880"

# Тимчасово: dashboard UI без редиректа на /login (API все одно вимагає cookie)
# NEXT_PUBLIC_SKIP_AUTH=false
